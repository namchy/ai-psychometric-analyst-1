{
  "$schema": "https://repomix.com/schemas/latest/schema.json",
  "input": {
    "maxFileSize": 52428800
  },
  "output": {
    "filePath": "repomix-output-ai-daily.xml",
    "style": "xml",
    "parsableStyle": false,
    "fileSummary": true,
    "directoryStructure": true,
    "files": true,
    "removeComments": false,
    "removeEmptyLines": false,
    "compress": false,
    "topFilesLength": 5,
    "showLineNumbers": false,
    "truncateBase64": false,
    "copyToClipboard": false,
    "includeFullDirectoryStructure": false,
    "tokenCountTree": false,
    "git": {
      "sortByChanges": true,
      "sortByChangesMaxCommits": 100,
      "includeDiffs": false,
      "includeLogs": false,
      "includeLogsCount": 50
    }
  },
  "include": [
    "AGENTS.md",
    "docs/deep-profile-todo.md",
    "package.json",
    "tsconfig.json",
    "next.config.js",
    "postcss.config.js",
    "tailwind.config.ts",
    ".eslintrc.json",
    "playwright.config.ts",
    "app/assessment/page.tsx",
    "app/actions/assessment.ts",
    "app/(protected)/dashboard/page.tsx",
    "app/(protected)/dashboard/attempts/[attemptId]/run/page.tsx",
    "app/(protected)/dashboard/attempts/[attemptId]/page.tsx",
    "app/(protected)/app/attempts/[attemptId]/practice/page.tsx",
    "app/(protected)/app/attempts/[attemptId]/practice/[exampleIndex]/page.tsx",
    "app/(protected)/app/attempts/[attemptId]/report/page.tsx",
    "app/(protected)/app/attempts/[attemptId]/report/loading.tsx",
    "app/(protected)/app/attempts/[attemptId]/report/error.tsx",
    "app/(protected)/app/attempts/[attemptId]/report/report-back-button.tsx",
    "components/assessment/**/*.tsx",
    "components/dashboard/candidate-dashboard.tsx",
    "components/dashboard/create-assessment-form.tsx",
    "components/dashboard/create-assessment-modal-state.ts",
    "components/dashboard/create-assessment-modal.tsx",
    "components/dashboard/hr-assessments-table.tsx",
    "components/dashboard/primitives.tsx",
    "components/dashboard/single-open-panel-group.tsx",
    "lib/candidate/attempts.ts",
    "lib/assessment/attempt-lifecycle.ts",
    "lib/assessment/availability.ts",
    "lib/assessment/completion-server.ts",
    "lib/assessment/completion.ts",
    "lib/assessment/display.ts",
    "lib/assessment/ipc-report-contract.ts",
    "lib/assessment/ipc-report-v1.ts",
    "lib/assessment/ipip-neo-120-labels.ts",
    "lib/assessment/ipip-neo-120-participant-ai-input-v2.ts",
    "lib/assessment/ipip-neo-120-participant-report-v2-segments.ts",
    "lib/assessment/ipip-neo-120-participant-report-v2.ts",
    "lib/assessment/ipip-neo-120-report-contract.ts",
    "lib/assessment/ipip-neo-120-report-v1.ts",
    "lib/assessment/ipip-participant-report-display.ts",
    "lib/assessment/locale.ts",
    "lib/assessment/mwms-attempt-scoring.ts",
    "lib/assessment/mwms-participant-ai-input-v1.ts",
    "lib/assessment/mwms-participant-report-v1.ts",
    "lib/assessment/mwms-report-contract.ts",
    "lib/assessment/mwms-scoring.ts",
    "lib/assessment/prompt-version.ts",
    "lib/assessment/protected-attempts.ts",
    "lib/assessment/report-config.ts",
    "lib/assessment/report-job-worker.ts",
    "lib/assessment/report-provider-helpers.ts",
    "lib/assessment/report-provider-mock.ts",
    "lib/assessment/report-provider-openai.ts",
    "lib/assessment/report-provider-registry.ts",
    "lib/assessment/report-providers.ts",
    "lib/assessment/report-runtime-config.ts",
    "lib/assessment/reports.ts",
    "lib/assessment/result-display.ts",
    "lib/assessment/safran-interpretation.ts",
    "lib/assessment/safran-practice.ts",
    "lib/assessment/schemas/detailed-report-v1-openai.json",
    "lib/assessment/schemas/detailed-report-v1.json",
    "lib/assessment/schemas/ipc-hr-report-v1.json",
    "lib/assessment/schemas/ipc-participant-report-v1.json",
    "lib/assessment/schemas/ipip-neo-120-hr-v1.json",
    "lib/assessment/schemas/ipip-neo-120-participant-v1.json",
    "lib/assessment/schemas/mwms-participant-report-v1.json",
    "lib/assessment/scoring.ts",
    "lib/assessment/standard-battery.ts",
    "lib/assessment/test-localizations.ts",
    "lib/assessment/tests.ts",
    "lib/assessment/types.ts",
    "scripts/verify-candidate-flow.mjs",
    "scripts/verify-report-worker-trigger.cjs",
    "scripts/test-attempt-lifecycle.cjs",
    "scripts/test-mwms-scoring.cjs",
    "scripts/test-mwms-report-display.cjs",
    "scripts/test-mwms-completed-flow.cjs",
    "scripts/test-safran-interpretation.cjs",
    "scripts/audit-safran-stimuli.cjs",
    "scripts/test-safran-v1-scoring.cjs",
    "scripts/test-ipip-neo-120-participant-report.mjs",
    "scripts/verify-ipip-participant-consistency.cjs",
    "scripts/verify-ipip-neo-120-participant-ai-input-v2.cjs",
    "scripts/verify-ipip-neo-120-participant-ai-input-v2-builder.cjs",
    "scripts/verify-ipip-neo-120-participant-v2-renderer.cjs",
    "scripts/verify-mwms-prompts.cjs",
    "scripts/activate-mwms-prompts.cjs",
    "tests/ui-smoke/auth.ts",
    "tests/ui-smoke/user-dashboard.spec.ts",
    "tests/ui-smoke/hr-dashboard.spec.ts",
    "tests/ui-smoke/hr-dashboard-layout-inspection.spec.ts",
    "tests/ui-smoke/protected-resume.spec.ts"
  ],
  "ignore": {
    "useGitignore": true,
    "useDotIgnore": true,
    "useDefaultPatterns": true,
    "customPatterns": [
      "public/tests/**",
      "assessment-packages/**",
      "supabase/migrations/**",
      "backup_data.sql",
      "baze1.txt",
      "IPC Canonical Implementation Spec v1.txt",
      "*.Zone.Identifier",
      "repomix-output*.xml"
    ]
  },
  "security": {
    "enableSecurityCheck": true
  },
  "tokenCount": {
    "encoding": "o200k_base"
  }
}
