[
  { "code": "FG01", "text": "Tih sam u društvu nepoznatih ljudi." },
  { "code": "HI01", "text": "Govorim tiho." },
  { "code": "JK01", "text": "Toleriram mnogo toga od drugih." },
  { "code": "LM01", "text": "Zanimaju me ljudi." },
  { "code": "NO01", "text": "Osjećam se ugodno u društvu ljudi." },
  { "code": "PA01", "text": "Zahtijevam da budem u središtu pažnje." },
