  { "code": "DE01", "text": "Vjerujem da bi se ljudi trebali sami snalaziti." },
  { "code": "FG02", "text": "Vrlo sam zatvorena i privatna osoba." },
  { "code": "HI02", "text": "Puštam druge da završe ono što govore." },
