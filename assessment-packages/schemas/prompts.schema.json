      "audience": { "type": "string" },
      "report_type": { "type": "string" },
      "source_type": { "type": "string" },
      "generator_type": { "type": "string" },
      "version": { "type": "string" },
      "is_active": { "type": "boolean" },
      "system_prompt": { "type": "string" },
      "user_prompt_template": { "type": "string" },
      "output_schema_json": {},
