[
  { "code": "E01", "text": "Unosim živost u neku zabavu." },
  { "code": "A01", "text": "Ne brinem se puno za druge ljude." },
  { "code": "C01", "text": "Uvijek sam spreman (spremna)." },
  { "code": "ES01", "text": "Lako podliježem stresu." },
  { "code": "O01", "text": "Imam bogat rječnik." },
  { "code": "E02", "text": "Ne pričam puno." },
  { "code": "A02", "text": "Zanimaju me drugi ljudi." },
  { "code": "C02", "text": "Ostavljam svoje stvari posvuda." },
  { "code": "ES02", "text": "Uglavnom se osjećam opušteno." },
  { "code": "O02", "text": "Teško razumijem apstraktne ideje." },
  { "code": "E03", "text": "Osjećam se ugodno u društvu." },
  { "code": "A03", "text": "Vrijeđam ljude." },
  { "code": "C03", "text": "Obraćam pažnju na detalje." },
  { "code": "ES03", "text": "Često sam zabrinut (zabrinuta)." },
  { "code": "O03", "text": "Imam bujnu maštu." },
  { "code": "E04", "text": "Držim se po strani." },
  { "code": "A04", "text": "Suosjećam s drugima." },
  { "code": "C04", "text": "Pravim nered." },
  { "code": "ES04", "text": "Rijetko sam tužan (tužna)." },
  { "code": "O04", "text": "Ne zanimaju me apstraktne ideje." },
  { "code": "E05", "text": "Sam(a) započinjem razgovore." },
  { "code": "A05", "text": "Ne zanimaju me tuđi problemi." },
  { "code": "C05", "text": "Odmah obavljam kućne poslove." },
  { "code": "ES05", "text": "Lako me zasmetati." },
  { "code": "O05", "text": "Imam izvrsne ideje." },
  { "code": "E06", "text": "Imam malo toga za reći." },
  { "code": "A06", "text": "Imam meko srce." },
  { "code": "C06", "text": "Često zaboravljam vratiti stvari na njihovo mjesto." },
  { "code": "ES06", "text": "Lako se uzrujam." },
  { "code": "O06", "text": "Nemam mnogo mašte." },
  { "code": "E07", "text": "Na zabavama razgovaram s mnogo različitih osoba." },
  { "code": "A07", "text": "Drugi ljudi me zapravo ne zanimaju." },
  { "code": "C07", "text": "Volim red." },
  { "code": "ES07", "text": "Često mijenjam raspoloženja." },
  { "code": "O07", "text": "Brzo shvaćam različite stvari." },
  { "code": "E08", "text": "Ne volim privlačiti pažnju." },
  { "code": "A08", "text": "Posvećujem vrijeme drugim ljudima." },
  { "code": "C08", "text": "Izbjegavam obveze." },
  { "code": "ES08", "text": "Podliježem čestim promjenama raspoloženja." },
  { "code": "O08", "text": "Koristim učene izraze." },
  { "code": "E09", "text": "Nije mi nelagodno biti u središtu pozornosti." },
  { "code": "A09", "text": "Osjetljiv(a) sam na tuđe osjećaje." },
  { "code": "C09", "text": "Slijedim zacrtani plan." },
  { "code": "ES09", "text": "Lako me je razdražiti." },
  { "code": "O09", "text": "Provodim vrijeme razmišljajući." },
  { "code": "E10", "text": "Šutljiv(a) sam s nepoznatima." },
  { "code": "A10", "text": "Nastojim da se drugi osjećaju ugodno." },
  { "code": "C10", "text": "Posao obavljam točno i precizno." },
  { "code": "ES10", "text": "Često sam tužan (tužna)." },
  { "code": "O10", "text": "Pun(a) sam ideja." }
]
