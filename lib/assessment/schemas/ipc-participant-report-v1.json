{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://deep-profile.local/schemas/ipc-participant-report-v1.json",
  "title": "IPC Participant Report v1",
  "description": "Canonical schema for IPIP-IPC participant reports in AI Psychometric Analyst for HR v1.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "report_title",
    "report_subtitle",
    "summary",
    "style_snapshot",
    "strengths_in_collaboration",
    "watchouts",
    "development_recommendations",
    "disclaimer"
  ],
  "properties": {
    "report_title": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "report_subtitle": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "summary": {
      "$ref": "#/$defs/summary"
    },
    "style_snapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "primary_disc",
        "dominant_octant",
        "secondary_octant"
      ],
      "properties": {
        "primary_disc": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "D",
            "I",
            "S",
            "C",
            null
          ]
        },
        "dominant_octant": {
          "$ref": "#/$defs/ipcOctant"
        },
        "secondary_octant": {
          "$ref": "#/$defs/ipcOctant"
        }
      }
    },
    "strengths_in_collaboration": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {
        "$ref": "#/$defs/titleDescriptionItem"
      }
    },
    "watchouts": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": {
        "$ref": "#/$defs/titleDescriptionItem"
      }
    },
    "development_recommendations": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {
        "$ref": "#/$defs/developmentRecommendationItem"
      }
    },
    "disclaimer": {
      "$ref": "#/$defs/nonEmptyString"
    }
  },
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "ipcOctant": {
      "type": "string",
      "enum": [
        "PA",
        "BC",
        "DE",
        "FG",
        "HI",
        "JK",
        "LM",
        "NO"
      ]
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "headline",
        "overview"
      ],
      "properties": {
        "headline": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "overview": {
          "$ref": "#/$defs/nonEmptyString"
        }
      }
    },
    "titleDescriptionItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "description"
      ],
      "properties": {
        "title": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "description": {
          "$ref": "#/$defs/nonEmptyString"
        }
      }
    },
    "developmentRecommendationItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "description",
        "action"
      ],
      "properties": {
        "title": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "description": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "action": {
          "$ref": "#/$defs/nonEmptyString"
        }
      }
    }
  }
}
