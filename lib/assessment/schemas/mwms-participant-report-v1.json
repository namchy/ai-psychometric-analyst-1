{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://deep-profile.local/schemas/mwms-participant-report-v1.json",
  "title": "MWMS Participant Report v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "test_slug",
    "audience",
    "title",
    "summary",
    "motivation_pattern",
    "key_observations",
    "possible_tensions",
    "reflection_questions",
    "development_suggestions",
    "interpretation_note"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "mwms_participant_report_v1" },
    "test_slug": { "type": "string", "const": "mwms_v1" },
    "audience": { "type": "string", "const": "participant" },
    "title": { "type": "string", "const": "Radna motivacija" },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["headline", "paragraph"],
      "properties": {
        "headline": { "$ref": "#/$defs/nonEmptyString" },
        "paragraph": { "$ref": "#/$defs/nonEmptyString" }
      }
    },
    "motivation_pattern": {
      "type": "object",
      "additionalProperties": false,
      "required": ["autonomous", "controlled", "amotivation"],
      "properties": {
        "autonomous": { "$ref": "#/$defs/nonEmptyString" },
        "controlled": { "$ref": "#/$defs/nonEmptyString" },
        "amotivation": { "$ref": "#/$defs/nonEmptyString" }
      }
    },
    "key_observations": {
      "type": "array",
      "minItems": 1,
      "maxItems": 3,
      "items": { "$ref": "#/$defs/nonEmptyString" }
    },
    "possible_tensions": {
      "type": "array",
      "minItems": 1,
      "maxItems": 3,
      "items": { "$ref": "#/$defs/nonEmptyString" }
    },
    "reflection_questions": {
      "type": "array",
      "minItems": 1,
      "maxItems": 3,
      "items": { "$ref": "#/$defs/nonEmptyString" }
    },
    "development_suggestions": {
      "type": "array",
      "minItems": 1,
      "maxItems": 3,
      "items": { "$ref": "#/$defs/nonEmptyString" }
    },
    "interpretation_note": { "$ref": "#/$defs/nonEmptyString" }
  },
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    }
  }
}
