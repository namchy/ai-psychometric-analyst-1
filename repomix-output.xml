          report_type = v_prompt ->> 'report_type',
          audience = v_prompt ->> 'audience',
          source_type = v_prompt ->> 'source_type',
          generator_type = v_prompt ->> 'generator_type',
          prompt_key = v_prompt ->> 'prompt_key',
