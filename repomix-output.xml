        raise exception 'Prompt localization for locale % references unknown prompt_version %/% (%/%/%).',
          v_prompt_locale ->> 'locale',
          v_prompt ->> 'prompt_key',
          v_prompt ->> 'version',
          v_prompt ->> 'report_type',
          v_prompt ->> 'audience',
          v_prompt ->> 'generator_type';
      end if;

      insert into public.prompt_version_localizations (
