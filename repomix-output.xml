.login-card {
  position: relative;
  width: min(100%, 440px);
  padding: 36px 32px 30px;
  border: 1px solid rgba(148, 171, 192, 0.11);
  border-radius: 30px;
  background:
    radial-gradient(circle at top, rgba(120, 160, 204, 0.08), transparent 42%),
    linear-gradient(180deg, rgba(24, 37, 50, 0.96), rgba(15, 25, 35, 0.97)),
    rgba(16, 26, 37, 0.94);
  box-shadow:
    0 24px 56px rgba(4, 8, 14, 0.26),
    0 4px 14px rgba(6, 11, 18, 0.16),
    inset 0 1px 0 rgba(255, 255, 255, 0.05);
  backdrop-filter: blur(20px);
}

.login-card::before {
  content: "";
  position: absolute;
  inset: 0;
  border-radius: inherit;
  background:
    linear-gradient(180deg, rgba(146, 184, 220, 0.08), transparent 19%),
    linear-gradient(180deg, transparent 70%, rgba(9, 15, 21, 0.12) 100%);
  pointer-events: none;
}

.login-card::after {
  content: "";
  position: absolute;
  inset: 1px;
  border-radius: calc(30px - 1px);
  border: 1px solid rgba(255, 255, 255, 0.03);
  pointer-events: none;
}

.login-card__header {
  position: relative;
  display: grid;
  gap: 16px;
  margin-bottom: 30px;
}

.login-card__brand {
  margin: 0;
  color: rgba(235, 242, 250, 0.92);
  font-size: 1.36rem;
  line-height: 1;
  font-weight: 780;
  letter-spacing: -0.035em;
}

.login-card__heading-group {
  display: grid;
  gap: 12px;
}

.login-card__heading-group h2 {
  margin: 0;
  color: #f6f9fc;
  font-size: 2.14rem;
  line-height: 1.02;
  font-weight: 790;
  letter-spacing: -0.04em;
}

.login-card__heading-group p {
  margin: 0;
  max-width: 32ch;
  color: rgba(194, 207, 221, 0.8);
  font-size: 0.95rem;
  line-height: 1.72;
  font-weight: 500;
}

.login-form {
  position: relative;
  display: grid;
  gap: 20px;
}

.login-form__fields {
  display: grid;
  gap: 15px;
}

.login-form__field {
  display: grid;
  gap: 9px;
}

.login-form__label {
  color: rgba(214, 225, 236, 0.82);
  font-size: 0.76rem;
  line-height: 1.4;
  font-weight: 720;
  letter-spacing: 0.09em;
  text-transform: uppercase;
}

.login-form__input-wrap {
  position: relative;
  display: block;
  border: 1px solid rgba(65, 77, 83, 0.1);
  border-radius: 16px;
  background:
    linear-gradient(180deg, rgba(15, 47, 59, 0.94), rgba(11, 42, 52, 0.9)),
    rgba(11, 42, 52, 0.9);
  box-shadow:
    inset 0 1px 0 rgba(255, 255, 255, 0.03),
    inset 0 -1px 0 rgba(0, 10, 14, 0.18);
  transition: all 300ms ease;
}

.login-form__input-wrap:focus-within {
  border-color: rgba(157, 215, 240, 0.4);
  box-shadow:
    0 0 0 4px rgba(157, 215, 240, 0.1),
    inset 0 1px 0 rgba(255, 255, 255, 0.04);
}

.login-form__icon {
  position: absolute;
  top: 50%;
  left: 16px;
  z-index: 1;
  width: 18px;
  height: 18px;
  color: rgba(196, 231, 255, 0.6);
  transform: translateY(-50%);
  pointer-events: none;
  transition: color 300ms ease;
}

.login-form__input-wrap:focus-within .login-form__icon {
  color: rgba(157, 215, 240, 0.92);
}

.login-form__icon svg {
  width: 100%;
  height: 100%;
}

.login-form input:not([type="radio"]):not([type="checkbox"]) {
  min-height: 58px;
