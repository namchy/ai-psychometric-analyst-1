@keyframes assessment-completion-slide {
  0% {
    transform: translateX(-120%);
  }

  50% {
    transform: translateX(95%);
  }

  100% {
    transform: translateX(240%);
  }
}

@keyframes assessment-completion-rotate {
  to {
    transform: rotate(360deg);
  }
}

@keyframes assessment-completion-pulse {
  0%,
  100% {
    transform: scale(1);
    box-shadow: 0 0 0 0 rgba(41, 71, 111, 0.16);
  }

  55% {
    transform: scale(1.08);
    box-shadow: 0 0 0 0.75rem rgba(41, 71, 111, 0);
  }
}

