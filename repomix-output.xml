  if (error || !data.user) {
    fail(`Unable to create auth user ${email}: ${error?.message ?? "Unknown error"}`);
  }

  return data.user;
}

async function signInWithPassword(authSupabase, email, password) {
  const { data, error } = await authSupabase.auth.signInWithPassword({
