.results-panel--wide {
  grid-column: 1 / -1;
}

.results-panel__header {
  display: grid;
  gap: 0.35rem;
}

.results-panel__lead {
  margin: 0;
  font-size: 1.02rem;
  line-height: 1.8;
}

.results-bullet-list {
  display: grid;
  gap: 0.72rem;
}

.results-bullet-list li,
.results-inline-list li {
  position: relative;
  padding-left: 1rem;
  color: var(--text);
  line-height: 1.55;
}

.results-bullet-list li strong {
  color: #2f342d;
}

.results-bullet-list li::before,
.results-inline-list li::before {
  content: "";
  position: absolute;
  top: 0.72rem;
  left: 0;
  width: 0.38rem;
  height: 0.38rem;
  border-radius: 999px;
  background: #6a86a8;
}

