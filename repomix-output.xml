.login-experience {
  position: relative;
  width: 100%;
  min-height: 100vh;
  min-height: 100dvh;
  margin: 0;
  padding: 40px 40px 28px;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  background: var(--login-experience-bg);
  color: #f2f6fb;
}

.login-experience::before,
.login-experience::after {
  content: "";
  position: absolute;
  inset: auto;
  pointer-events: none;
  border-radius: 999px;
  filter: blur(70px);
  opacity: 0.42;
}

.login-experience::before {
  top: -120px;
  left: -60px;
  width: 320px;
  height: 320px;
  background: rgba(84, 132, 173, 0.18);
}

.login-experience::after {
  right: -80px;
  bottom: -100px;
  width: 360px;
  height: 360px;
  background: rgba(163, 109, 88, 0.12);
}

.login-experience__shell,
.login-experience__shell :where(h1, h2, p, span, label, a, button, input) {
  font-family: var(--font-manrope), var(--font-sans);
}

.login-experience__shell {
  position: relative;
  z-index: 1;
  width: min(100%, 1380px);
  margin: 0 auto;
  flex: 1;
  display: grid;
  grid-template-columns: minmax(0, 1.15fr) minmax(360px, 460px);
  gap: 48px;
  align-items: center;
}

.login-experience__hero {
  min-height: 100%;
  display: flex;
  align-items: center;
}

.login-experience__hero-inner {
  width: min(100%, 700px);
  display: grid;
  gap: 30px;
  padding: 28px 0;
}

.login-experience__badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: fit-content;
  min-height: 38px;
  padding: 0 16px;
  border: 1px solid rgba(133, 161, 188, 0.16);
  border-radius: 999px;
  background: linear-gradient(180deg, rgba(35, 52, 69, 0.72), rgba(18, 31, 42, 0.72));
  box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.06);
  color: #c8d7e6;
  font-size: 0.76rem;
  line-height: 1;
  font-weight: 760;
  letter-spacing: 0.1em;
  text-transform: uppercase;
}

.login-experience__title-block {
  display: grid;
  gap: 20px;
}

.login-experience__title {
  max-width: none;
  margin: 0;
  display: inline-flex;
  flex-direction: column;
  align-items: flex-start;
  font-family: Georgia, "Times New Roman", Times, serif;
  font-size: clamp(3.5rem, 6vw, 5.5rem);
  line-height: 0.98;
  font-weight: 600;
  letter-spacing: -0.045em;
  color: #f4f7fb;
}

.login-experience__title-line,
.login-experience__title-accent {
  display: block;
}

.login-experience__title-line {
  color: #f4f7fb;
}

.login-experience__title-accent {
  color: #9dd7f0;
  font-style: italic;
}

.login-experience__description {
  max-width: 34rem;
  margin: 0;
  color: rgba(213, 222, 233, 0.84);
  font-size: 1.08rem;
  line-height: 1.75;
  font-weight: 460;
}

.login-experience__stats {
  display: flex;
  flex-wrap: wrap;
  gap: 20px;
  padding-top: 10px;
}

.login-experience__stat {
  min-width: 150px;
