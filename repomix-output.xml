.assessment-completion-state__indicator {
  display: grid;
  justify-items: center;
  gap: 1rem;
  margin: 2rem 0 1.25rem;
}

.assessment-completion-state__indicator-orbit {
  position: relative;
  display: grid;
  place-items: center;
  width: 4.5rem;
  aspect-ratio: 1;
  border-radius: 999px;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.96), rgba(234, 240, 247, 0.72));
  box-shadow:
    inset 0 0 0 1px rgba(41, 71, 111, 0.08),
    0 18px 40px -30px rgba(41, 71, 111, 0.45);
}

.assessment-completion-state__indicator-orbit::before {
  content: "";
  position: absolute;
  inset: 0;
  border-radius: inherit;
  border: 1px solid rgba(41, 71, 111, 0.12);
}

.assessment-completion-state__indicator-orbit::after {
  content: "";
  position: absolute;
  inset: 0.3rem;
  border-radius: inherit;
  border: 2px solid rgba(41, 71, 111, 0.12);
  border-top-color: #29476f;
  border-right-color: rgba(80, 115, 160, 0.65);
  animation: assessment-completion-rotate 1100ms linear infinite;
}

.assessment-completion-state__indicator-core {
  width: 1rem;
  height: 1rem;
  border-radius: 999px;
  background: linear-gradient(180deg, #29476f 0%, #6b8bb3 100%);
  box-shadow: 0 0 0 0 rgba(41, 71, 111, 0.18);
  animation: assessment-completion-pulse 1800ms ease-out infinite;
}

.assessment-completion-state__indicator-bar {
  position: relative;
  display: block;
  width: min(100%, 18rem);
  height: 0.4rem;
  overflow: hidden;
  border-radius: 999px;
  background: linear-gradient(90deg, rgba(31, 58, 95, 0.08), rgba(31, 58, 95, 0.16));
}

.assessment-completion-state__indicator-bar::after {
  content: "";
  position: absolute;
  inset: 0;
  width: 34%;
  border-radius: inherit;
  background: linear-gradient(90deg, rgba(41, 71, 111, 0) 0%, #29476f 48%, #6b8bb3 100%);
  animation: assessment-completion-slide 1600ms ease-in-out infinite;
}

