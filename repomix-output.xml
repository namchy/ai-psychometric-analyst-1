  border-color: #c7b7a2;
  background: linear-gradient(180deg, rgba(250, 244, 235, 0.92) 0%, rgba(241, 231, 216, 0.98) 100%);
  box-shadow: 0 18px 30px -26px rgba(62, 53, 43, 0.2);
}

.assessment-step-actions__button--save:hover:not(:disabled) {
  border-color: #a8937a;
  background: linear-gradient(180deg, #f4e6d6 0%, #e5d3bf 100%);
  box-shadow: 0 20px 32px -24px rgba(78, 63, 49, 0.3);
}

.assessment-step-actions__button--ghost:focus-visible,
.assessment-step-actions__button--save:focus-visible,
.assessment-step-actions__button--primary:focus-visible {
  outline: 2px solid rgba(104, 120, 99, 0.22);
