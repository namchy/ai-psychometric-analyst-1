  }

  .results-report__section {
    gap: 16px;
  }

  .results-insight-list {
    gap: 12px;
  }

  .results-insight-list li {
    padding-left: 16px;
    font-size: 15px;
    line-height: 1.7;
    font-weight: 500;
    color: #41515f;
  }

  .results-insight-list li::before,
  .results-bullet-list li::before,
  .results-inline-list li::before {
    width: 6px;
    height: 6px;
    background: #1f6f8b;
  }

  .results-report__section-heading {
    gap: 8px;
  }

  .results-score-overview {
    gap: 20px;
  }

  .results-score-overview__item {
    gap: 10px;
    padding: 0;
    border: 0;
    background: transparent;
  }

  .results-score-overview__header strong {
    font-size: 18px;
    line-height: 1.3;
    font-weight: 700;
    letter-spacing: -0.01em;
    color: #14212b;
  }

  .results-score-overview__header span {
    font-size: 13px;
    line-height: 1.5;
    font-weight: 700;
    color: #41515f;
  }

  .results-score-overview__bar {
    height: 10px;
    background: #e2e8ee;
    box-shadow: none;
  }

  .results-score-overview__bar span {
    background: linear-gradient(90deg, #5c7c6a 0%, #1f6f8b 100%);
  }

  .results-dimension-list {
    gap: 20px;
  }

  .results-dimension-card {
    gap: 16px;
    padding: 24px;
    border: 1px solid #d8e0e7;
    border-radius: 20px;
    background: #fcfdfd;
    box-shadow: 0 10px 30px rgba(16, 24, 40, 0.05);
  }

  .results-dimension-card__header {
    align-items: flex-start;
    gap: 16px;
  }

  .results-dimension-card__title {
    gap: 4px;
  }

  .results-dimension-card__header h4 {
    font-size: 18px;
    line-height: 1.3;
    font-weight: 700;
    letter-spacing: -0.01em;
    color: #14212b;
